<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Your BibOn Credentials</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background-color: #f0f4f8; font-family: 'Segoe UI', Arial, sans-serif; padding: 32px 16px; color: #1a202c; }
    .wrapper { max-width: 560px; margin: 0 auto; }
    .header { background: linear-gradient(135deg, #1d4ed8 0%, #3b82f6 100%); border-radius: 16px 16px 0 0; padding: 32px 40px; text-align: center; }
    .header .brand { color: #bfdbfe; font-size: 13px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 16px; }
    .header .logo-img { width: 96px; height: 96px; object-fit: cover; border-radius: 12px; border: 3px solid rgba(255,255,255,0.3); margin-bottom: 16px; display: block; margin-left: auto; margin-right: auto; }
    .header .logo-placeholder { width: 96px; height: 96px; border-radius: 12px; background: rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; font-size: 36px; }
    .header h1 { color: #ffffff; font-size: 22px; font-weight: 700; line-height: 1.3; }
    .header p { color: #bfdbfe; font-size: 14px; margin-top: 6px; }
    .body { background: #ffffff; padding: 36px 40px; }
    .greeting { font-size: 17px; font-weight: 600; color: #1e3a5f; margin-bottom: 12px; }
    .intro { font-size: 14px; color: #4a5568; line-height: 1.7; margin-bottom: 28px; }
    .intro strong { color: #1d4ed8; }
    .credentials-box { background: #f8faff; border: 1.5px solid #dbeafe; border-radius: 12px; padding: 24px 28px; margin-bottom: 28px; }
    .credentials-box h2 { font-size: 12px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: #93c5fd; margin-bottom: 16px; }
    .credential-row { margin-bottom: 14px; }
    .credential-row:last-child { margin-bottom: 0; }
    .credential-label { font-size: 11px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 4px; }
    .credential-value { background: #ffffff; border: 1px solid #e2e8f0; border-radius: 8px; padding: 10px 14px; font-family: 'Courier New', monospace; font-size: 15px; color: #1e293b; font-weight: 600; letter-spacing: 0.5px; }
    .cta { text-align: center; margin-bottom: 28px; }
    .cta a { display: inline-block; background: linear-gradient(135deg, #1d4ed8 0%, #3b82f6 100%); color: #ffffff; text-decoration: none; font-size: 15px; font-weight: 700; padding: 14px 36px; border-radius: 50px; letter-spacing: 0.3px; }
    .note { background: #fffbeb; border-left: 4px solid #f59e0b; border-radius: 0 8px 8px 0; padding: 14px 18px; margin-bottom: 28px; }
    .note p { font-size: 13px; color: #92400e; line-height: 1.6; }
    .divider { border: none; border-top: 1px solid #e2e8f0; margin: 0 0 24px; }
    .footer { padding: 0 40px 32px; text-align: center; }
    .footer p { font-size: 12px; color: #94a3b8; line-height: 1.6; }
    .footer .brand-footer { font-weight: 700; color: #3b82f6; font-size: 14px; display: block; margin-bottom: 6px; }
  </style>
</head>
<body>
  <div class="wrapper">

    <!-- Header -->
    <div class="header">
      <div class="brand">BibOn — Race Management Platform</div>
      {{#if logoUrl}}
        <img class="logo-img" src="{{logoUrl}}" alt="{{eventName}}" />
      {{else}}
        <div class="logo-placeholder">🏃</div>
      {{/if}}
      <h1>{{#if eventName}}{{eventName}}{{else}}Welcome to the Race!{{/if}}</h1>
      <p>{{raceName}}</p>
    </div>

    <!-- Body -->
    <div class="body">
      <p class="greeting">Dear {{fullName}},</p>
      <p class="intro">
        We are pleased to confirm your registration for <strong>{{raceName}}</strong>{{#if eventName}} as part of <strong>{{eventName}}</strong>{{/if}}.<br /><br />
        Your participant account has been created. Use the credentials below to access your personal dashboard where you can track your registration, bib number, and race results.
      </p>

      <!-- Credentials -->
      <div class="credentials-box">
        <h2>Your Login Credentials</h2>
        <div class="credential-row">
          <div class="credential-label">Email</div>
          <div class="credential-value">{{email}}</div>
        </div>
        <div class="credential-row">
          <div class="credential-label">Password</div>
          <div class="credential-value">{{password}}</div>
        </div>
      </div>

      <!-- CTA -->
      <div class="cta">
        <a href="http://localhost:3000/login">Access My Dashboard →</a>
      </div>

      <!-- Note -->
      <div class="note">
        <p>🔒 &nbsp;Please keep this email safe. We recommend changing your password after your first login. If you did not register for this event, you can safely ignore this message.</p>
      </div>
    </div>

    <hr class="divider" />

    <!-- Footer -->
    <div class="footer">
      <span class="brand-footer">BibOn</span>
      <p>The smart platform for sports event management.<br />
      This is an automated message — please do not reply to this email.</p>
    </div>

  </div>
</body>
</html>
